# Copie para .env e ajuste. NUNCA versione o .env real (adicione ao .gitignore).

# PostgreSQL (ADR-004)
POSTGRES_DB=laboratorio
POSTGRES_USER=lab_app
POSTGRES_PASSWORD=troque-esta-senha

# MinIO / S3 (ADR-005)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=troque-esta-senha
MINIO_BUCKET=artigos

# Vault / criptografia envelope (ADR-007)
# Em produção NÃO se usa token de dev: troca-se por AppRole com política mínima.
VAULT_TOKEN=dev-root-token-troque
VAULT_KEK_NAME=kek-artigos

# SMTP institucional (RF08/RF22)
SMTP_HOST=smtp.instituicao.br
SMTP_PORT=587
